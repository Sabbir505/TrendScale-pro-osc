plotshape(showEOT and eotShowPressure and eotPressureBear ? eotTrigger : na, title="EOT Pressure Bear", style=shape.circle, location=location.absolute, color=color.red, size=size.tiny)

// EOT Overbought Warnings (circles at bottom)
plotshape(showEOT and eotShowOBWarn and eotOBWarn1 and not eotOBWarn2 ? eotOSLevel - 0.2 : na, title="EOT OB Warn", style=shape.circle, location=location.absolute, color=color.orange, size=size.tiny)
plotshape(showEOT and eotShowOBWarn and eotOBWarn2 ? eotOSLevel - 0.2 : na, title="EOT OB Strong", text="OB", textcolor=color.red, style=shape.circle, location=location.absolute, color=color.red, size=size.tiny)

