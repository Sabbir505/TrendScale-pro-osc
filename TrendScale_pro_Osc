plotshape(showEOT and eotShowCont and eotContShort ? eotOBLevel + 0.15 : na, title="EOT Cont Short", text="Cont", textcolor=color.white, style=shape.triangledown, location=location.absolute, color=color.red, size=size.small)

// EOT Bounce Signals
plotshape(showEOT and eotShowBounce and eotBounceDown ? eotOBLevel + 0.05 : na, title="EOT Bounce Down", style=shape.triangledown, location=location.absolute, color=color.yellow, size=size.tiny)
plotshape(showEOT and eotShowBounce and eotBounceUp ? eotOSLevel - 0.05 : na, title="EOT Bounce Up", style=shape.triangleup, location=location.absolute, color=color.yellow, size=size.tiny)

