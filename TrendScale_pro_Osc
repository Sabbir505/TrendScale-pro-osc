showComb = displayMode == "Combined"

// Three oscillator lines
plot(showComb ? combRSI : na, title="Comb RSI", color=color.orange, linewidth=1)
plot(showComb ? combSDO : na, title="Comb SDO", color=color.white, linewidth=1)
plot(showComb ? combEOT : na, title="Comb EOT", color=color.blue, linewidth=1)

// Flow Fill (Cloud)
combMaxPlot = plot(showComb and combShowFlow ? combMax : na, title="Flow Max", color=color.new(color.white, 100), display=display.none)
combMinPlot = plot(showComb and combShowFlow ? combMin : na, title="Flow Min", color=color.new(color.white, 100), display=display.none)

combCloudColor = combCloudBull ? color.new(color.green, combCloudTransp) : color.new(color.red, combCloudTransp)
fill(combMaxPlot, combMinPlot, color=showComb and combShowFlow ? combCloudColor : na, title="Flow Cloud")

// Flow Center Line
plot(showComb and combShowCenter ? combCenter : na, title="Flow Center", color=combCenterColor, linewidth=2)

// Combined levels
hline(showComb ? 70 : na, title="Comb OB", color=color.new(color.red, 50), linestyle=hline.style_dashed)
hline(showComb ? 30 : na, title="Comb OS", color=color.new(color.green, 50), linestyle=hline.style_dashed)
hline(showComb ? 50 : na, title="Comb Mid", color=color.new(color.gray, 70), linestyle=hline.style_dotted)

// Combined signal markers
// RSI divergence = squares
plotshape(showComb and rsiBullDiv ? combRSI[rsiPivotLen] : na, title="Comb RSI Bull", style=shape.square, location=location.absolute, color=color.green, size=size.tiny, offset=-rsiPivotLen)
plotshape(showComb and rsiBearDiv ? combRSI[rsiPivotLen] : na, title="Comb RSI Bear", style=shape.square, location=location.absolute, color=color.red, size=size.tiny, offset=-rsiPivotLen)

// SDO cross = triangles
plotshape(showComb and sdoLongSignal ? combSDO : na, title="Comb SDO Long", style=shape.triangleup, location=location.absolute, color=color.white, size=size.tiny)
plotshape(showComb and sdoShortSignal ? combSDO : na, title="Comb SDO Short", style=shape.triangledown, location=location.absolute, color=color.white, size=size.tiny)

// EOT entry = circles
plotshape(showComb and eotLongAny ? combEOT : na, title="Comb EOT Long", style=shape.circle, location=location.absolute, color=color.green, size=size.tiny)
plotshape(showComb and eotShortRed ? combEOT : na, title="Comb EOT Short", style=shape.circle, location=location.absolute, color=color.red, size=size.tiny)

// Confluence Labels
plotshape(showComb and confluenceLong ? 15 : na, title="★ LONG", text="★ LONG", textcolor=color.white, style=shape.labelup, location=location.absolute, color=color.green, size=size.tiny)
plotshape(showComb and confluenceShort ? 85 : na, title="★ SHORT", text="★ SHORT", textcolor=color.white, style=shape.labeldown, location=location.absolute, color=color.red, size=size.tiny)

